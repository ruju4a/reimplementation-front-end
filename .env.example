# Copy to .env.production and set your backend URL (no trailing slash).
# Vite inlines this value at **build** time — rebuild the image if you change it.
#
# Local backend in Docker:
#   VITE_API_BASE_URL=http://localhost:3002
# VCL / remote backend:
#   VITE_API_BASE_URL=http://YOUR_PUBLIC_IP:3002

VITE_API_BASE_URL=http://localhost:3002
